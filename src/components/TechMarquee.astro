---
const techStack = [
	"React Native",
	"Next.js",
	"Nest.js",
	"React",
	"TypeScript",
	"Node.js",
	"Tailwind CSS",
	"Astro",
	"PostgreSQL",
	"Docker",
];
---

<div
	class="relative w-full overflow-hidden bg-zinc-900/30 border-y border-zinc-800/50 py-3 my-8 backdrop-blur-sm flex">
	<!-- Размытые края -->
	<div
		class="absolute inset-y-0 left-0 w-12 bg-gradient-to-r from-zinc-950 to-transparent z-10 pointer-events-none">
	</div>
	<div
		class="absolute inset-y-0 right-0 w-12 bg-gradient-to-l from-zinc-950 to-transparent z-10 pointer-events-none">
	</div>

	<!-- Главный трюк: ДВЕ абсолютно одинаковые ленты, которые движутся синхронно -->
	<!-- pr-8 (отступ справа) должен быть равен gap-8, чтобы расстояние на стыке двух лент не ломалось -->
	<div
		class="flex items-center gap-8 animate-marquee whitespace-nowrap pr-8 shrink-0 select-none">
		{
			techStack.map((tech) => (
				<div class="flex items-center gap-3 text-sm font-mono font-medium text-zinc-400">
					<span>{tech}</span>
					<span class="w-1.5 h-1.5 rounded-full bg-hardev-orange/60" />
				</div>
			))
		}
	</div>

	<!-- Копия первой ленты -->
	<div
		class="flex items-center gap-8 animate-marquee whitespace-nowrap pr-8 shrink-0 select-none"
		aria-hidden="true">
		{
			techStack.map((tech) => (
				<div class="flex items-center gap-3 text-sm font-mono font-medium text-zinc-400">
					<span>{tech}</span>
					<span class="w-1.5 h-1.5 rounded-full bg-hardev-orange/60" />
				</div>
			))
		}
	</div>
</div>
