---
import AboutSection from "../components/home/AboutSection.astro";
import FormSection from "../components/home/FormSection.astro";
import HeroSection from "../components/home/HeroSection.astro";
import TechSection from "../components/home/TechSection.astro";
import WaySection from "../components/home/WaySection.astro";
import TechMarquee from "../components/TechMarquee.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout description="Hello Site">
	<main>
		<HeroSection class="[@media(max-height:530px)]:mb-10" />
		<TechMarquee class="mb-10" />
		<AboutSection class="mb-10" />
		<TechSection class="mb-10" />
		<WaySection class="mb-10" />
		<FormSection />
	</main>
</Layout>
